# Frontend Environment Variables
# Copy this file to .env and fill in your values

# API URL — leave blank in production (uses same-origin), set for local dev
VITE_API_URL=http://localhost:5300

# App Config
VITE_APP_TITLE=Pokhrel Flex Printing
VITE_APP_DESCRIPTION=Quality printing solutions for retail and wholesale

# Contact Info (optional — used for static display)
VITE_CONTACT_EMAIL=your-email@example.com
VITE_CONTACT_PHONE=+977 000 000 0000

# Analytics (optional)
VITE_GA_TRACKING_ID=

# Feature Flags
VITE_ENABLE_CONTACT_FORM=true
VITE_ENABLE_ANALYTICS=false
